{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Owlbox",
    "version": "0.1.0",
    "identifier": "com.github.mgxv.owlbox",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [],
        "security": {
            "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app", "dmg"],
        "icon": ["icons/icon.icns"],
        "macOS": {
            "minimumSystemVersion": "15.0"
        }
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": ["mailto"]
            }
        },
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1MkIzNThCOTc1ODA1OEYKUldTUEJWaVhpelVyMVNuaWwrekhXUlJjZk1EczVmR2Y4Y2xLR2ZYZFIyWlFFWC9ZemFMOVFSdncK",
            "endpoints": [
                "https://github.com/mgxv/owlbox/releases/latest/download/latest.json"
            ]
        }
    }
}
